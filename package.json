{
  "name": "snapex",
  "displayName": "SnapEx",
  "description": "Back up and restore installed VS Code extensions, configuration values, selected external state files, and best-effort storage state into separate zip archives.",
  "version": "0.1.4",
  "publisher": "local-tools",
  "license": "MIT",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:snapex.actions",
    "onCommand:extensionStateBackup.backupAll",
    "onCommand:extensionStateBackup.backupSelected",
    "onCommand:extensionStateBackup.restoreFromZip",
    "onCommand:extensionStateBackup.openBackupFolder"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extensionStateBackup.backupAll",
        "title": "Backup All Extensions",
        "category": "SnapEx",
        "icon": "$(archive)"
      },
      {
        "command": "extensionStateBackup.backupSelected",
        "title": "Backup Selected Extension",
        "category": "SnapEx",
        "icon": "$(extensions)"
      },
      {
        "command": "extensionStateBackup.restoreFromZip",
        "title": "Restore Extension from Zip",
        "category": "SnapEx",
        "icon": "$(history)"
      },
      {
        "command": "extensionStateBackup.openBackupFolder",
        "title": "Open Backup Folder",
        "category": "SnapEx",
        "icon": "$(folder-opened)"
      }
    ],
    "configuration": {
      "title": "SnapEx",
      "properties": {
        "extensionStateBackup.defaultBackupLocation": {
          "type": "string",
          "default": "",
          "description": "Optional absolute folder path where extension backup runs are written. When empty, you will be prompted each time."
        },
        "extensionStateBackup.includeBuiltIn": {
          "type": "boolean",
          "default": false,
          "description": "Include built-in VS Code extensions in backup runs. Usually leave this disabled because built-ins are restored by VS Code itself."
        },
        "extensionStateBackup.includeExtensionFiles": {
          "type": "boolean",
          "default": true,
          "description": "Include each extension's installed files in its backup archive. Disable this only when you want configuration and storage state snapshots."
        },
        "extensionStateBackup.includeCurrentWorkspaceStorage": {
          "type": "boolean",
          "default": true,
          "description": "Include the current workspace storage folder for each extension when available. Other workspaces are not scanned."
        },
        "extensionStateBackup.confirmBeforeRestore": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before overwriting an installed extension directory, global storage, workspace storage, external state files, or configuration values."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "snapex",
          "title": "SnapEx",
          "icon": "snapex-icon.png"
        }
      ]
    },
    "views": {
      "snapex": [
        {
          "id": "snapex.actions",
          "name": "Actions"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "snapex.actions",
        "contents": "[Backup All Extensions](command:extensionStateBackup.backupAll)\n[Backup Selected Extension](command:extensionStateBackup.backupSelected)\n[Restore Extension from Zip](command:extensionStateBackup.restoreFromZip)\n[Open Backup Folder](command:extensionStateBackup.openBackupFolder)"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "test": "npm run compile && node test/smoke-test.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.92.0",
    "typescript": "^5.5.4",
    "@vscode/vsce": "^3.6.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ngpepin/snapex.git"
  },
  "icon": "snapex-icon.png"
}
